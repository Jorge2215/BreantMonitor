{
  "routes": [
    {
      "route": "/Data/*.json",
      "headers": {
        "Cache-Control": "public, max-age=3600, must-revalidate",
        "Content-Type": "application/json; charset=utf-8"
      }
    },
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "public, max-age=600, must-revalidate"
      }
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/Index.html",
      "statusCode": 200
    }
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
